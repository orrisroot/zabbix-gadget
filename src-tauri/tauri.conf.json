{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zabbix-gadget",
  "version": "0.1.1",
  "identifier": "com.github.orrisroot.zabbix-gadget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zabbix Gadget",
        "width": 670,
        "height": 300,
        "minWidth": 670,
        "minHeight": 90,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": true,
        "center": false,
        "x": 100,
        "y": 100
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 420,
        "height": 420,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "url": "index.html?window=settings"
      },
      {
        "label": "tooltip",
        "title": "Tooltip",
        "width": 550,
        "height": 300,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": true,
        "visible": false,
        "url": "index.html?window=tooltip"
      },
      {
        "label": "update",
        "title": "Software Update",
        "width": 440,
        "height": 290,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": true,
        "visible": false,
        "url": "index.html?window=update",
        "center": true
      },
      {
        "label": "connection-edit",
        "title": "Connection Target",
        "width": 380,
        "height": 400,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "url": "index.html?window=connection-edit"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCRjVBQ0NBQ0RBMzQ2QQpSV1JxTk5xc3pGcS9DOE1ReTRjNWJkUFhQUGF6bnN4cWhxNEtXQU4vSGVEd1BLMGdsYzd4NktKRwo=",
      "endpoints": ["https://github.com/orrisroot/zabbix-gadget/releases/latest/download/latest.json"]
    }
  }
}
